# =============================================================================
# Xiaozhi CE (Community Edition) - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# ===== DATABASE =====
POSTGRES_USER=xiaozhi_db
POSTGRES_PASSWORD=your_secure_db_password_here
POSTGRES_DB=xiaozhi_db
DATABASE_URL=postgresql+asyncpg://xiaozhi_db:your_secure_db_password_here@db:5432/xiaozhi_db

# ===== REDIS =====
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_URL=redis://:your_secure_redis_password_here@redis:6379/0

# ===== MQTT (EMQX) =====
MQTT_BROKER_HOST=emqx
MQTT_BROKER_PORT=1883
MQTT_USERNAME=xiaozhi
MQTT_PASSWORD=your_secure_mqtt_password_here
MQTT_DASHBOARD_PASSWORD=your_mqtt_dashboard_password
EMQX_ALLOW_ANONYMOUS=false

# ===== SERVER =====
# Secret key for JWT tokens - generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_SECRET_KEY=change_me_to_a_random_secret_key
SERVER_URL=http://localhost:8000

# ===== AI PROVIDERS (Fill in the ones you want to use) =====

# OpenAI - For LLM, TTS, and ASR
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini - For LLM
GEMINI_API_KEY=your-gemini-key-here

# DeepSeek - For LLM (OpenAI-compatible)
# Use OpenAI provider with custom base URL
# DEEPSEEK_API_KEY=your-deepseek-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Qwen (Alibaba) - For LLM (OpenAI-compatible)
# QWEN_API_KEY=your-qwen-key-here
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== OPTIONAL =====

# Sentry error tracking
# SENTRY_DSN=

# Environment mode: development, staging, production
ENVIRONMENT=production

# Admin email for first-time setup
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
